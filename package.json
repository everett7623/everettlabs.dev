{
  "name": "everettlabs.dev",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate:og && npm run sync:github && astro build",
    "preview": "astro preview",
    "sync:github": "tsx scripts/sync-github.ts",
    "generate:og": "tsx scripts/generate-og.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "validate:static": "npm run lint && npm run format:check && npm run validate:size && npm run validate:projects && npm run validate:links && npm run validate:a11y && npm run validate:github && npm run validate:security && npm run validate:site && npm run test",
    "validate:size": "tsx scripts/validate-source-size.ts",
    "validate:projects": "tsx scripts/validate-projects.ts",
    "validate:links": "tsx scripts/validate-links.ts",
    "validate:links:external": "tsx scripts/validate-links.ts --external",
    "validate:a11y": "tsx scripts/validate-accessibility.ts",
    "validate:github": "tsx scripts/validate-github-metadata.ts",
    "validate:security": "tsx scripts/validate-security.ts",
    "validate:site": "tsx scripts/validate-site.ts",
    "typecheck": "astro check",
    "test": "vitest run tests",
    "test:e2e": "playwright test",
    "audit:lighthouse": "tsx scripts/run-lighthouse.ts",
    "audit:lighthouse:production": "tsx scripts/run-lighthouse.ts --config=.lighthouserc.production.json"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "lucide-react": "^0.477.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.5",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.5",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^16.5.0",
    "jsonc-parser": "^3.3.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.7.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
