---
import type { Project } from '../utils/projects.ts';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: Project[];
  compact?: boolean;
}

const { projects, compact = false } = Astro.props;
---

<div
  class:list={[
    'grid gap-4',
    compact ? 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4' : 'grid-cols-1 md:grid-cols-2',
  ]}
>
  {projects.map((project) => <ProjectCard project={project} compact={compact} />)}
</div>
