---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<article
  class="rounded-lg border border-border bg-surface p-5 text-left sm:p-6"
  aria-labelledby="ko-fi-heading"
  data-support-method="ko-fi"
>
  <div class="grid items-center gap-6 md:grid-cols-[minmax(0,1fr)_minmax(18rem,0.85fr)]">
    <div class="min-w-0">
      <p class="font-mono text-xs tracking-widest text-accent-cyan">ONE-TIME SUPPORT</p>
      <h2 id="ko-fi-heading" class="mt-2 text-2xl font-semibold text-text-primary">Ko-fi</h2>
      <p class="mt-3 max-w-xl text-sm leading-6 text-text-secondary">
        Make a one-time contribution through the official Everett Labs Ko-fi page.
      </p>
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex min-h-11 items-center justify-center gap-2 rounded-md bg-accent-violet px-5 py-2 text-sm font-medium text-white transition hover:bg-accent-violet/90"
        aria-label="Support Everett Labs on Ko-fi (opens in a new tab)"
      >
        Support on Ko-fi
        <span aria-hidden="true">↗</span>
      </a>
    </div>

    <img
      src="/coffee/ko-fi.png"
      alt="Support Everett Labs on Ko-fi"
      width="672"
      height="356"
      decoding="async"
      class="aspect-[672/356] w-full rounded-md object-cover"
    />
  </div>
</article>
