---
import type { Project } from '../utils/projects.ts';
import Badge from './Badge.astro';

interface Props {
  project: Project;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { data } = project;

let badgeText = '';
let badgeVariant: 'primary' | 'warning' | 'secondary' = 'primary';

if (data.slug === 'linketry') {
  badgeText = 'FLAGSHIP';
  badgeVariant = 'primary';
} else if (data.status === 'beta') {
  badgeText = 'BETA';
  badgeVariant = 'warning';
} else if (data.category === 'community') {
  badgeText = 'COMMUNITY';
  badgeVariant = 'secondary';
}

const statusVariantMap: Record<string, 'success' | 'warning' | 'secondary' | 'neutral'> = {
  active: 'success',
  stable: 'secondary',
  beta: 'warning',
  maintained: 'secondary',
  experimental: 'neutral',
  archived: 'neutral',
};

const index = String(data.homeOrder).padStart(2, '0');
---

<a
  href={`/projects/${data.slug}`}
  class="group relative flex flex-col rounded-xl border border-border bg-surface p-6 transition-all hover:border-text-muted hover:bg-surface-raised"
>
  <div class="flex items-start justify-between gap-4">
    <span class="font-mono text-xs text-text-muted">{index}</span>
    {badgeText && <Badge text={badgeText} variant={badgeVariant} />}
  </div>

  <h3
    class="mt-4 font-sans text-lg font-semibold text-text-primary group-hover:text-accent-cyan transition-colors"
  >
    {data.name}
  </h3>

  {!compact && <p class="mt-2 text-sm text-text-secondary line-clamp-3">{data.summary}</p>}

  <div class="mt-4 flex flex-wrap gap-2">
    <Badge text={data.status} variant={statusVariantMap[data.status] ?? 'neutral'} />
    {data.ownership === 'community' && <Badge text="community" variant="secondary" />}
  </div>

  <div class="mt-auto pt-6 flex items-center justify-between text-xs text-text-muted">
    <div class="flex flex-wrap gap-2">
      {
        data.tags
          .slice(0, compact ? 3 : 5)
          .map((tag) => (
            <span class="rounded bg-surface-raised px-1.5 py-0.5 font-mono">{tag}</span>
          ))
      }
    </div>

    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
      aria-hidden="true"
    >
      <path d="M7 7h10v10"></path>
      <path d="M7 17 17 7"></path>
    </svg>
  </div>

  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-1 scale-x-0 bg-accent-cyan transition-transform group-hover:scale-x-100 rounded-b-xl"
    aria-hidden="true"
  >
  </div>
</a>
