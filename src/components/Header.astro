---
import { site } from '../utils/site.ts';
import { Command } from 'lucide-react';
---

<header class="sticky top-0 z-40 border-b border-border bg-background/80 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a
      href="/"
      class="inline-flex min-h-11 items-center font-mono text-sm font-semibold tracking-widest text-text-primary hover:text-accent-cyan transition-colors"
    >
      EVERETT LABS
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-text-secondary md:flex">
      <a
        href="/projects"
        class="inline-flex min-h-11 items-center hover:text-text-primary transition-colors"
        >Projects</a
      >
      <a
        href={site.seedloc}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-11 items-center gap-1 hover:text-text-primary transition-colors"
      >
        Writing <span aria-hidden="true">↗</span>
      </a>
      <a
        href="/about"
        class="inline-flex min-h-11 items-center hover:text-text-primary transition-colors">About</a
      >
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-11 items-center gap-1 hover:text-text-primary transition-colors"
      >
        GitHub <span aria-hidden="true">↗</span>
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        aria-label="Open command palette"
        aria-keyshortcuts="Control+K Meta+K"
        data-command-trigger
        class="inline-flex min-h-11 items-center gap-2 rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-secondary hover:border-text-muted hover:text-text-primary transition-colors"
      >
        <Command size={16} />
        <span class="hidden sm:inline">Ctrl K</span>
      </button>
      <a
        href={site.telegram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Telegram"
        class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-md border border-border bg-surface p-2 text-text-secondary hover:border-text-muted hover:text-text-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="m22 2-7 20-4-7-7-4Z"></path><path d="M22 2 11 13"></path></svg
        >
      </a>
    </div>
  </div>
</header>

<script>
  import { COMMAND_PALETTE_EVENT } from '../utils/events';

  const trigger = document.querySelector('[data-command-trigger]');
  trigger?.addEventListener('click', () => {
    window.dispatchEvent(new Event(COMMAND_PALETTE_EVENT));
  });
</script>
